# 데이터베이스 설정
DATABASE_URL=postgresql+asyncpg://boj_user:boj_password@db:5432/boj_soma_db

# JWT 보안 설정
SECRET_KEY=your-super-secret-key-change-in-production-please-make-it-very-long-and-random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS 설정 (프로덕션에서는 특정 도메인만 허용)
BACKEND_CORS_ORIGINS=["*"]

# 프로젝트 정보
PROJECT_NAME=BOJ SOMA Manager
VERSION=0.1.0
